{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "жІүжөёйҳ…иҜ»",
  "version": "1.1.0",
  "identifier": "com.lingcang.immersivereading",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.ico",
      "iconAsTemplate": false,
      "tooltip": "жІүжөёйҳ…иҜ»"
    },
    "windows": [
      {
        "title": "жІүжөёйҳ…иҜ»",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: tauri:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:*; frame-src 'self' http://127.0.0.1:*; img-src 'self' asset: tauri: data: blob: http: https:; style-src 'self' 'unsafe-inline' asset: tauri:; script-src 'self' asset: tauri:; font-src 'self' asset: tauri: data:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

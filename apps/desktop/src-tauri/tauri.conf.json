{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "豐画ｵｸ髦ɬｯｻ",
  "version": "1.0.0",
  "identifier": "com.lingcang.immersivereading",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "豐画ｵｸ髦ɬｯｻ",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

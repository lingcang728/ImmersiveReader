{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://immersive-reader.local/schemas/manifest-v1.json",
  "title": "Immersive Reader Book Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "bookId", "title", "source", "generatedAt", "updatedAt", "chapters"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "bookId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "source": { "enum": ["zhihu", "manual", "podcast"] },
    "sourceId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "title", "voteCount", "wordCount"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(/|$)).+$" },
          "title": { "type": "string", "minLength": 1 },
          "date": { "type": "string", "format": "date" },
          "voteCount": { "type": "integer", "minimum": 0 },
          "wordCount": { "type": "integer", "minimum": 0 },
          "metadataStatus": { "enum": ["complete", "inferred"] }
        }
      }
    }
  }
}
